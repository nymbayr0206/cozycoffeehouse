<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Top-level menu under Point of Sale -->
    <menuitem
        id="menu_kitchen_display_root"
        name="Kitchen Display"
        parent="point_of_sale.menu_point_of_sale"
        sequence="25"
        groups="point_of_sale.group_pos_manager,pos_kitchen_display.group_kitchen_staff"/>

    <!-- Kitchen Display Board (fullscreen OWL view) -->
    <menuitem
        id="menu_kitchen_display_board"
        name="Live Display"
        parent="menu_kitchen_display_root"
        action="action_kitchen_display_board"
        sequence="10"
        groups="point_of_sale.group_pos_manager,pos_kitchen_display.group_kitchen_staff"/>

    <!-- Kitchen Orders backend list (for managers) -->
    <menuitem
        id="menu_kitchen_order_list"
        name="Kitchen Orders"
        parent="menu_kitchen_display_root"
        action="action_kitchen_order_list"
        sequence="20"
        groups="point_of_sale.group_pos_manager"/>

</odoo>
