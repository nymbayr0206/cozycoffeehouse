<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Client Action: Kitchen Display Board ─────────────────────── -->
    <record id="action_kitchen_display_board" model="ir.actions.client">
        <field name="name">Kitchen Display</field>
        <field name="tag">kitchen_display_action</field>
        <field name="target">fullscreen</field>
    </record>

    <!-- ─── Kitchen Order: List View ─────────────────────────────────── -->
    <record id="view_kitchen_order_list" model="ir.ui.view">
        <field name="name">kitchen.order.list</field>
        <field name="model">kitchen.order</field>
        <field name="arch" type="xml">
            <list string="Kitchen Orders" decoration-success="status == 'done'"
                  decoration-warning="status == 'in_progress'"
                  decoration-danger="elapsed_minutes &gt; 20 and status != 'done'">
                <field name="name"/>
                <field name="table_number"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'done'"
                       decoration-warning="status == 'in_progress'"
                       decoration-info="status == 'pending'"/>
                <field name="elapsed_minutes" string="Elapsed (min)"/>
                <field name="create_date" string="Received At"/>
                <field name="start_time"/>
                <field name="done_time"/>
                <button name="action_in_progress" string="In Progress" type="object"
                        class="fa fa-play" invisible="status != 'pending'"/>
                <button name="action_done" string="Done" type="object"
                        class="fa fa-check" invisible="status == 'done'"/>
            </list>
        </field>
    </record>

    <!-- ─── Kitchen Order: Form View ─────────────────────────────────── -->
    <record id="view_kitchen_order_form" model="ir.ui.view">
        <field name="name">kitchen.order.form</field>
        <field name="model">kitchen.order</field>
        <field name="arch" type="xml">
            <form string="Kitchen Order">
                <header>
                    <button name="action_in_progress" string="Mark In Progress"
                            type="object" class="btn-warning"
                            invisible="status != 'pending'"/>
                    <button name="action_done" string="Mark Done"
                            type="object" class="btn-success"
                            invisible="status == 'done'"/>
                    <button name="action_reset_pending" string="Reset to Pending"
                            type="object"
                            invisible="status == 'pending'"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,in_progress,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="table_number"/>
                            <field name="pos_order_id"/>
                        </group>
                        <group>
                            <field name="create_date" string="Received At"/>
                            <field name="start_time"/>
                            <field name="done_time"/>
                            <field name="elapsed_minutes"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Order note..."/>
                    <notebook>
                        <page string="Order Lines">
                            <field name="line_ids">
                                <list>
                                    <field name="product_name"/>
                                    <field name="qty"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ─── Kitchen Order: Search View ──────────────────────────────── -->
    <record id="view_kitchen_order_search" model="ir.ui.view">
        <field name="name">kitchen.order.search</field>
        <field name="model">kitchen.order</field>
        <field name="arch" type="xml">
            <search string="Kitchen Orders">
                <field name="name"/>
                <filter string="Pending" name="filter_pending"
                        domain="[('status', '=', 'pending')]"/>
                <filter string="In Progress" name="filter_in_progress"
                        domain="[('status', '=', 'in_progress')]"/>
                <filter string="Done" name="filter_done"
                        domain="[('status', '=', 'done')]"/>
            </search>
        </field>
    </record>

    <!-- ─── Action: Kitchen Order List ───────────────────────────────── -->
    <record id="action_kitchen_order_list" model="ir.actions.act_window">
        <field name="name">Kitchen Orders</field>
        <field name="res_model">kitchen.order</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_nocontent_help">
                No kitchen orders yet
            </p>
            <p>Kitchen orders are created automatically when POS orders are placed.</p>
        </field>
    </record>

    <!-- ─── POS Order: add "Send to Kitchen" button ───────────────────── -->
    <record id="view_pos_order_form_kitchen" model="ir.ui.view">
        <field name="name">pos.order.form.kitchen</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_to_kitchen"
                        string="Send to Kitchen"
                        type="object"
                        class="btn-primary"
                        invisible="state == 'cancel'"/>
            </xpath>
        </field>
    </record>

</odoo>
