<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_qpay" model="ir.ui.view">
        <field name="name">sale.order.form.qpay</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_qpay_transactions"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-credit-card"
                    invisible="qpay_transaction_count == 0"
                    groups="group_qpay_user"
                >
                    <field name="qpay_transaction_count" widget="statinfo" string="QPay"/>
                </button>

                <button name="action_create_qpay_transaction"
                    type="object"
                    string="QPay-р төлөх"
                    class="oe_stat_button"
                    icon="fa-qrcode"
                    invisible="state not in ['sale','done'] or qpay_paid"
                    groups="group_qpay_user"
                />
            </xpath>
        </field>
    </record>
</odoo>
