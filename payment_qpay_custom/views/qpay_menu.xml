<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Үндсэн цэс -->
    <menuitem
        id="menu_qpay_root"
        name="QPay"
        sequence="90"
        groups="group_qpay_user"
    />

    <!-- Гүйлгээнүүд -->
    <record id="action_qpay_transaction_list" model="ir.actions.act_window">
        <field name="name">QPay Гүйлгээнүүд</field>
        <field name="res_model">qpay.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem
        id="menu_qpay_transactions"
        name="Гүйлгээнүүд"
        parent="menu_qpay_root"
        action="action_qpay_transaction_list"
        sequence="10"
        groups="group_qpay_user"
    />

    <!-- Тохиргоо руу холбоос -->
    <menuitem
        id="menu_qpay_config"
        name="Тохиргоо"
        parent="menu_qpay_root"
        action="base_setup.action_general_configuration"
        sequence="50"
        groups="group_qpay_manager"
    />
</odoo>
