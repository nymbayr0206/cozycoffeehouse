<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_form_qpay" model="ir.ui.view">
        <field name="name">account.move.form.qpay</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- QPay товч нэхэмжлэлийн header-т -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_qpay_transactions"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-credit-card"
                    invisible="qpay_transaction_count == 0"
                    groups="group_qpay_user"
                >
                    <field name="qpay_transaction_count" widget="statinfo" string="QPay"/>
                </button>
            </xpath>

            <!-- QPay төлбөр хийх товч -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_create_qpay_transaction"
                    type="object"
                    string="QPay-р төлөх"
                    class="oe_stat_button"
                    icon="fa-qrcode"
                    invisible="state != 'posted' or move_type not in ['out_invoice','out_refund'] or payment_state in ['paid','in_payment'] or qpay_paid"
                    groups="group_qpay_user"
                />
            </xpath>
        </field>
    </record>
</odoo>
