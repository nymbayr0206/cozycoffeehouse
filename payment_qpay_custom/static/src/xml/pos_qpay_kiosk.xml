<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!--
        PaymentPage template-ийг өргөтгөж QPay QR код харуулна.
        Хэрэглэгч QPay сонгосон үед:
          - QR ачаалж байвал: spinner
          - QR бэлэн болсон: QR зураг + богино холбоос
          - Алдаа: алдааны мэдэгдэл
        Бусад tермinalуудад (Adyen, Stripe) өмнөх байдлаараа ажиллана.
    -->
    <t t-inherit="pos_self_order.PaymentPage" t-inherit-mode="extension">
        <!-- "payment-state-container" div-ийг QPay-д тохируулан орлуулна -->
        <xpath expr="//div[hasclass('payment-state-container')]" t-operation="replace">
            <!-- ── QPay: ачаалж байна ── -->
            <t t-if="!state.selection and isQPaySelected and state.qpayLoading">
                <div class="payment-state-container d-flex flex-column gap-4 align-items-center justify-content-center w-75 mx-auto p-3">
                    <h1 class="mb-2 text-center">QPay QR код бэлтгэж байна...</h1>
                    <div class="spinner-border text-primary" style="width:4rem;height:4rem;" role="status">
                        <span class="visually-hidden">Ачаалж байна...</span>
                    </div>
                </div>
            </t>

            <!-- ── QPay: QR код харуулна ── -->
            <t t-elif="!state.selection and isQPaySelected and state.qpayQR">
                <div class="payment-state-container d-flex flex-column gap-3 align-items-center justify-content-center w-75 mx-auto p-3">
                    <h1 class="mb-1 text-center">QPay-аар төлнө үү</h1>
                    <p class="text-muted text-center mb-0">
                        Та QPay апп нээж доорх QR кодыг уншуулна уу
                    </p>
                    <div class="border border-2 rounded p-2 bg-white shadow-sm">
                        <img
                            t-att-src="'data:image/png;base64,' + state.qpayQR"
                            alt="QPay QR код"
                            style="width:260px;height:260px;object-fit:contain;"
                        />
                    </div>
                    <t t-if="state.qpayShortUrl">
                        <a
                            t-att-href="state.qpayShortUrl"
                            class="btn btn-outline-primary btn-sm"
                            target="_blank"
                        >
                            Апп нээх →
                        </a>
                    </t>
                    <p class="text-muted small text-center mt-1">
                        Төлбөр баталгаажсаны дараа автоматаар үргэлжилнэ
                    </p>
                </div>
            </t>

            <!-- ── QPay: алдаа ── -->
            <t t-elif="!state.selection and isQPaySelected and state.qpayError">
                <div class="payment-state-container d-flex flex-column gap-4 align-items-center justify-content-center w-75 mx-auto p-3">
                    <h1 class="mb-2 text-center text-danger">QPay алдаа</h1>
                    <p class="text-center" t-esc="state.qpayError"/>
                </div>
            </t>

            <!-- ── Бусад terminal (Adyen, Stripe, ...) ── -->
            <t t-elif="!state.selection and !isQPaySelected">
                <div class="payment-state-container d-flex flex-column gap-4 align-items-center justify-content-center w-50 mx-auto p-3">
                    <h1 class="mb-3 text-center">Follow instructions on the terminal</h1>
                    <div class="btn btn-light btn-lg w-100 py-5 border border-light shadow-sm">
                        <i class="fa fa-credit-card-alt fa-3x" aria-hidden="true"/>
                    </div>
                </div>
            </t>
        </xpath>
    </t>

</templates>
