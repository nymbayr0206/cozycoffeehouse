<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- QPay гүйлгээний дугаарлалт -->
    <record id="sequence_qpay_transaction" model="ir.sequence">
        <field name="name">QPay Гүйлгээ</field>
        <field name="code">qpay.transaction</field>
        <field name="prefix">QPAY/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Хүлээгдэж буй гүйлгээг автоматаар шалгах cron -->
    <record id="cron_qpay_check_payments" model="ir.cron">
        <field name="name">QPay: Хүлээгдэж буй төлбөрүүд шалгах</field>
        <field name="model_id" ref="model_qpay_transaction"/>
        <field name="state">code</field>
        <field name="code">model.cron_check_pending_payments()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>
</odoo>
